PORT=3000
NODE_ENV=development

# Database configuration
DB_DIALECT=mysql
DB_HOST=localhost
DB_NAME=dholera
DB_USER=root
DB_PASS=

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Admin authentication
ADMIN_USER=admin
ADMIN_PASS=change_this_password
JWT_SECRET=change_this_to_a_long_random_secret
ADMIN_LOCKOUT_THRESHOLD=5
ADMIN_LOCKOUT_MS=1800000
ADMIN_LOGIN_WINDOW_MS=900000
ADMIN_LOGIN_MAX_ATTEMPTS=10
ADMIN_ACCESS_TOKEN_TTL_SECONDS=900
ADMIN_REFRESH_TOKEN_TTL_SECONDS=2592000
ADMIN_MFA_SECRET=
ADMIN_MFA_ISSUER=Dholera Growth Evidence Platform

# Server session
SESSION_SECRET=change_this_to_another_long_secret
# Optional Redis URL for session store (recommended in production)
REDIS_URL=

# Audit export/rotation
AUDIT_EXPORT_DIR=./audit_exports
AUDIT_EXPORT_AFTER_DAYS=30
AUDIT_EXPORT_RETENTION_DAYS=365

# WhatsApp Cloud API (optional in local dev; OTP falls back to console logs if unset)
WHATSAPP_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_OTP_TEMPLATE_NAME=otp_verification
WHATSAPP_LEAD_ALERT_TEMPLATE_NAME=lead_alert
WHATSAPP_TEMPLATE_LANGUAGE=en_US
ADMIN_WHATSAPP_NUMBERS=

# Email notifications for high-interest leads
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL_TO=
